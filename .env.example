NODE_ENV=development
PORT=4000

# CORS: comma-separated allowlist for production deploys (e.g. https://petpod.app).
# In dev, any http://localhost:<port> is allowed automatically — leave this empty.
FRONTEND_ORIGINS=

# Database (Neon connection string — get one at https://console.neon.tech/)
# Format: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# JWT secrets — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Cookies (leave COOKIE_DOMAIN blank for localhost; set in production)
COOKIE_DOMAIN=
COOKIE_SECURE=false

# Cloudinary (image hosting — sign up at https://cloudinary.com)
# Found under Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
